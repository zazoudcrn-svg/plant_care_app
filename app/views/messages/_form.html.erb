<%= form_with model: [plant, chat, message] do |f| %>
  <div class="input-group">
    <%= f.text_area :content, class: "form-control", placeholder: "Ask about your plant...", rows: 2, data: { action: "keydown->submit-on-enter#submit" } %>
    <%= f.submit "Send", class: "btn btn-success" %>
  </div>
<% end %>

<script>
  document.querySelector("textarea").addEventListener("keydown", function(e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      this.closest("form").requestSubmit();
    }
  });
</script>
