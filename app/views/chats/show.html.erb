<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <%= link_to "← Back to #{@plant.name}", plant_path(@plant), class: "text-success text-decoration-none fw-semibold mb-4 d-inline-block" %>
      <h1 class="mb-4"><%= @chat.title %></h1>

      <div class="mb-4">
        <% @messages.each do |message| %>
          <div class="d-flex mb-3 <%= message.role == 'user' ? 'justify-content-end' : 'justify-content-start' %>">
            <div class="p-3 rounded" style="max-width: 75%; background: <%= message.role == 'user' ? '#d4edda' : '#f8f9fa' %>;">
              <small class="text-muted d-block mb-1"><%= message.role.capitalize %></small>
              <%= message.content %>
            </div>
          </div>
        <% end %>
      </div>

      <%= form_with model: [@plant, @chat, Message.new] do |f| %>
        <div class="input-group">
          <%= f.text_area :content, class: "form-control", placeholder: "Ask about your plant...", rows: 2 %>
          <%= f.submit "Send", class: "btn btn-success" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
