<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <%= link_to "← Back to #{@plant.name}", plant_path(@plant), class: "text-success text-decoration-none fw-semibold mb-4 d-inline-block" %>
      <h1 class="mb-4" id="chat_title"><%= @chat.title.present? ? @chat.title : "Untitled" %></h1>

      <div class="mb-4" id="messages" data-controller="scroll" data-action="turbo:before-stream-render@document->scroll#scroll" style="height: 60vh; overflow-y: auto;">
        <%= render @messages %>
      </div>

      <div id="new_message_container">
        <%= render "messages/form", plant: @plant, chat: @chat, message: Message.new %>
      </div>

    </div>
  </div>
</div>
