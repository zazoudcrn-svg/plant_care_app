<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Chats about <%= @plant.name %></h1>
    <%= button_to "New chat", plant_chats_path(@plant), method: :post, class: "btn btn-success" %>
  </div>

  <% @chats.each do |chat| %>
    <div class="card mb-3">
      <div class="card-body d-flex justify-content-between align-items-center">
        <span><%= chat.title %></span>
        <%= link_to "Open", plant_chat_path(@plant, chat), class: "btn btn-sm btn-outline-success" %>
      </div>
    </div>
  <% end %>

  <%= link_to "Back to plant", plant_path(@plant), class: "btn btn-outline-secondary mt-2" %>
</div>
