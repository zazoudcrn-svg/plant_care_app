<div class="container my-5">
  <h1 class="mb-4 text-success fw-bold">Edit Plant</h1>

  <%= form_with model: @plant, local: true, class: "bg-white p-4 rounded-3 shadow-sm border" do |f| %>

    <div class="mb-3">
      <%= f.label :name, class: "form-label fw-semibold" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :specie, "Species", class: "form-label fw-semibold" %>
      <%= f.text_field :specie, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :plant_location, "Location", class: "form-label fw-semibold" %>
      <%= f.text_field :plant_location, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :sunlight_exposure, "Sunlight Exposure", class: "form-label fw-semibold" %>
      <%= f.text_field :sunlight_exposure, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :date_added, "When did you get this plant?", class: "form-label fw-semibold" %>
      <%= f.date_field :date_added, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :last_watered_on, "Last Watered On", class: "form-label fw-semibold" %>
      <%= f.date_field :last_watered_on, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :last_fertilized_on, "Last Fertilized On", class: "form-label fw-semibold" %>
      <%= f.date_field :last_fertilized_on, class: "form-control" %>
    </div>

    <div class="form-group">
       <%= f.label :photos %>
       <%= f.file_field :photos, multiple: true, accept: "image/*", class: "form-control" %>
    </div>


    <div class="d-flex gap-3 mt-4">
      <%= f.submit "Save changes", class: "btn btn-success px-4" %>
      <%= link_to "Cancel", @plant, class: "btn btn-outline-secondary" %>
    </div>

  <% end %>
</div>
