<div class="container my-5">
  <h1 class="mb-4 text-success fw-bold">Edit Plant</h1>

  <%= simple_form_for(@plant, html: { class: "bg-white p-4 rounded-3 shadow-sm border" }) do |f| %>
    <%= f.error_notification %>

    <%= hidden_field_tag :return_to, params[:return_to] %>

    <div class="form-inputs">
      <%= f.input :name, placeholder: "e.g. Monty", required: true %>

      <div data-controller="autocomplete-plant" style="position: relative;" class="mb-3">
        <%= f.input :specie,
                    label: "Species",
                    placeholder: "e.g. Monstera",
                    required: true,
                    input_html: {
                      data: {
                        autocomplete_plant_target: "input",
                        action: "input->autocomplete-plant#search"
                      },
                      autocomplete: "off"
                    } %>
        <div data-autocomplete-plant-target="results"></div>
      </div>

      <%= f.input :plant_location, label: "Location", placeholder: "e.g. Living room" %>

      <%= f.input :sunlight_exposure,
                  label: "Sunlight Exposure",
                  collection: ["Full sun", "Indirect sunlight", "Partial shade", "Shade"],
                  prompt: "Select sunlight needs...",
                  required: true %>

      <%= f.input :date_added,
                  as: :date,
                  label: "When did you get this plant?",
                  start_year: Date.today.year - 10,
                  end_year: Date.today.year,
                  order: [:day, :month, :year] %>

      <%= f.input :last_watered_on,
                  as: :date,
                  label: "Last Watered On",
                  start_year: Date.today.year - 1,
                  end_year: Date.today.year,
                  include_blank: true,
                  order: [:day, :month, :year] %>

      <%= f.input :last_fertilized_on,
                  as: :date,
                  label: "Last Fertilized On",
                  start_year: Date.today.year - 1,
                  end_year: Date.today.year,
                  include_blank: true,
                  order: [:day, :month, :year] %>

      <div class="form-group mb-3">
        <%= f.label :photos, "Upload Plant Image", class: "form-label fw-semibold" %>
        <%= f.file_field :photos, multiple: true, accept: "image/*", class: "form-control" %>
      </div>
    </div>

    <div class="form-actions d-flex gap-3 mt-4">
      <%= f.button :submit, "Save changes", class: "btn btn-success px-4" %>
      <%= link_to "Cancel", params[:return_to] == "index" ? plants_path : plant_path(@plant), class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
