<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <div class="card shadow-lg border-0 rounded-4 p-4 p-sm-5 bg-white">

        <div class="text-center mb-4">
          <div class="bg-success text-white rounded-3 p-3 shadow-sm d-inline-flex align-items-center justify-content-center mb-2" style="width: 55px; height: 55px;">
            <i class="fa-solid fa-seedling fs-4"></i>
          </div>
          <h2 class="fw-bold mt-2">Add a New Plant</h2>
        </div>

        <%= simple_form_for(@plant) do |f| %>
          <%= f.error_notification %>

          <div class="form-inputs">
            <%= f.input :name, placeholder: "e.g. Monty", required: true, autofocus: true %>
            <div data-controller="autocomplete-plant" style="position: relative;">
            <%= f.input :specie,
                        label: "Species",
                        placeholder: "e.g. Monstera",
                        required: true,
                        input_html: {
                          data: {
                            autocomplete_plant_target: "input",
                            action: "input->autocomplete-plant#search"
                          },
                          autocomplete: "off"
                        } %>
            <div data-autocomplete-plant-target="results"></div>
            </div> <%= f.input :plant_location, label: "Location", placeholder: "e.g. Living room" %>
            <%= f.input :sunlight_exposure,
                        label: "Sunlight Exposure",
                        collection: ["Full sun", "Indirect sunlight", "Partial shade", "Shade"],
                        prompt: "Select sunlight needs...",
                        required: true %>

            <%= f.input :last_watered_on, as: :date, label: "Last Watered On", start_year: Date.today.year - 1, end_year: Date.today.year, include_blank: true %>
            <%= f.input :last_fertilized_on, as: :date, label: "Last Fertilized On", start_year: Date.today.year - 1, end_year: Date.today.year, include_blank: true %>
          </div>
          <div class="form-actions mt-4 d-flex gap-2">
            <%= link_to "Cancel", plants_path, class: "btn btn-light border w-50 rounded-3" %>
            <%= f.button :submit, "Create Plant 🌱", class: "btn btn-success w-50 rounded-3" %>
          </div>
        <% end %>

      </div>

    </div>
  </div>
</div>
