<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold text-success mb-0">My Plant Collection 🌱</h1>

    <% unless @plants.empty? %>
      <%= link_to new_plant_path, class: "btn btn-success rounded-pill px-4 fw-semibold shadow-sm" do %>
        <i class="fa-solid fa-plus me-2"></i> Add Plant
      <% end %>
    <% end %>
  </div>

  <% if @plants.empty? %>
    <div class="text-center my-5 py-5">
      <p class="fs-4 mb-1">🪴</p>
      <p class="text-muted fs-5 mb-3">Ouh, you don't have any plants yet!</p>
      <%= link_to new_plant_path, class: "btn btn-success rounded-pill px-4 fw-semibold shadow-sm" do %>
        <i class="fa-solid fa-plus me-2"></i> Add your first Plant
      <% end %>
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% @plants.each do |plant| %>
        <div class="col">
          <div class="card h-100 shadow-sm border-0 rounded-3">
            <%#= image_tag "https://greenboog.com/wp-content/uploads/2023/11/Monstera-deliciosa.webp", class: "card-img-top rounded-top-3", style: "height: 200px; object-fit: cover;" %>
            <% if plant.photo.attached? %>
              <%= image_tag plant.photo,
                class: "card-img-top rounded-top-3",
                style: "height: 200px; object-fit: cover; cursor: pointer;",
                data: { upload_trigger: plant.id } %>
            <% else %>
              <div class="position-relative" style="height: 200px; cursor: pointer;" data-upload-trigger="<%= plant.id %>">
                <%= image_tag "placeholders.jpg",
                  class: "card-img-top rounded-top-3 opacity-50",
                  style: "height: 200px; object-fit: cover;" %>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center rounded-top-3" style="background: rgba(0,0,0,0.25);">
                  <i class="fa-solid fa-camera text-white fs-4 mb-1"></i>
                  <span class="text-white small fw-semibold">Add a photo</span>
                </div>
              </div>
            <% end %>

            <%= form_with model: plant,
              url: plant_path(plant, return_to: :index),
              method: :patch,
              data: { turbo_stream: true },
              html: { id: "upload-form-#{plant.id}" } do |f| %>
              <%= f.file_field :photo,
                accept: "image/*",
                style: "display: none;",
                id: "file-input-#{plant.id}" %>
            <% end %>

            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title fw-bold mb-0"><%= plant.name %></h5>
              </div>

              <p class="text-muted small italic mb-3">
                <i class="fa-solid fa-leaf text-success me-1"></i> <%= plant.specie %>
              </p>

              <% overdue = plant.last_watered_on.present? && plant.last_watered_on < 7.days.ago %>
              <p class="small mb-0">
                <strong>Last Watered:</strong>
                <span class="<%= 'text-danger fw-semibold' if overdue %>">
                  <%= plant.last_watered_on || "Never" %> <%= '🚨' if overdue %>
                </span>
              </p>

              <div class="d-flex justify-content-between align-items-center mt-auto pt-3">
                <div class="d-flex gap-2">
                  <%= link_to edit_plant_path(plant, return_to: :index), class: "btn btn-sm btn-outline-secondary rounded-pill" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                  <%= link_to plant_path(plant), data: { turbo_method: :delete, turbo_confirm: "Delete this plant?" }, class: "btn btn-sm btn-outline-danger rounded-pill" do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                </div>
                <%= link_to plant_path(plant), class: "btn btn-sm btn-success rounded-pill" do %>
                  <i class="fa-solid fa-arrow-right"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
