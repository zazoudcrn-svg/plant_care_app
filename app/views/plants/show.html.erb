<div class="container my-5">
  <%= link_to "← Back to my plants", plants_path, class: "text-success text-decoration-none fw-semibold mb-4 d-inline-block" %>

  <div class="row g-5">
    <div class="col-md-5">
      <div class="bg-white p-4 rounded-3 shadow-sm border h-100">
        <h1 class="fw-bold text-dark mb-1"><%= @plant.name %></h1>
        <p class="text-muted italic mb-4">Species: <%= @plant.specie %></p>

        <div class="table-responsive">
          <table class="table table-borderless align-middle small">
            <tbody>
              <tr>
                <td class="text-muted w-50">📍 Location:</td>
                <td class="fw-semibold"><%= @plant.plant_location %></td>
              </tr>
              <tr>
                <td class="text-muted">☀️ Sunlight:</td>
                <td class="fw-semibold"><%= @plant.sunlight_exposure %></td>
              </tr>
              <tr>
                <td class="text-muted">📅 Added on:</td>
                <td class="fw-semibold"><%= @plant.date_added %></td>
              </tr>
              <tr>
                <td class="text-muted">💧 Last Watered:</td>
                <td class="fw-semibold text-primary"><%= @plant.last_watered_on %></td>
              </tr>
              <tr>
                <td class="text-muted">🌿 Last Fertilized:</td>
                <td class="fw-semibold text-warning"><%= @plant.last_fertilized_on || "Not yet" %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-md-7">
      <div class="bg-white p-5 rounded-3 shadow-sm border h-100 d-flex flex-column align-items-center justify-content-center text-center">
        <div class="bg-light rounded-circle p-4 mb-4" style="width: 90px; height: 90px; display: flex; align-items: center; justify-content: center;">
          <span class="fs-1">🤖</span>
        </div>

        <h3 class="fw-bold text-dark mb-2">Need Care Advice for <%= @plant.name %>?</h3>
        <p class="text-muted mb-5 mx-auto" style="max-width: 420px;">
          Connect with our expert AI Assistant. Get personalized tips, disease diagnosis, and weather-aware guidance for your plant.
        </p>

        <%= link_to "#", class: "btn btn-success btn-lg px-5 rounded-pill fw-semibold shadow-sm d-inline-flex align-items-center transition" do %>
          Open Chat with <%= @plant.name %>
          <i class="fas fa-arrow-right ms-2"></i>
        <% end %>

        <small class="text-muted d-block mt-3" style="font-size: 0.75rem;">
          ⚡ A new view will open for the full chat session.
        </small>
      </div>
    </div>
  </div>
</div>
