<div class="container my-5">
  <%= link_to "← Back to my plants", plants_path, class: "text-success text-decoration-none fw-semibold mb-4 d-inline-block" %>

  <div class="row g-5">
    <div class="col-md-5">
      <div class="bg-white p-4 rounded-3 shadow-sm border">
        <h1 class="fw-bold text-dark mb-1"><%= @plant.name %></h1>
        <p class="text-muted italic mb-4">Species: <%= @plant.specie %></p>

        <div class="table-responsive">
          <table class="table table-borderless align-middle small">
            <tbody>
              <tr>
                <td class="text-muted w-50">📍 Location:</td>
                <td class="fw-semibold"><%= @plant.plant_location %></td>
              </tr>
              <tr>
                <td class="text-muted">☀️ Sunlight:</td>
                <td class="fw-semibold"><%= @plant.sunlight_exposure %></td>
              </tr>
              <tr>
                <td class="text-muted">📅 Added on:</td>
                <td class="fw-semibold"><%= @plant.date_added %></td>
              </tr>
              <tr>
                <td class="text-muted">💧 Last Watered:</td>
                <td class="fw-semibold text-primary"><%= @plant.last_watered_on %></td>
              </tr>
              <tr>
                <td class="text-muted">🌿 Last Fertilized:</td>
                <td class="fw-semibold text-warning"><%= @plant.last_fertilized_on || "Not yet" %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-md-7">
      <div class="card shadow-sm border-0 rounded-3 h-100 d-flex flex-column" style="min-height: 450px;">

        <div class="card-header bg-success text-white fw-bold py-3 border-0 rounded-top-3 d-flex align-items-center">
          <span class="fs-5 me-2">🤖</span> Chat with <%= @plant.name %>
        </div>

        <div class="card-body bg-light overflow-auto p-4 flex-grow-1" style="max-height: 320px;">

          <div class="d-flex mb-3 justify-content-start">
            <div class="bg-white p-3 rounded-3 shadow-sm border" style="max-width: 80%;">
              <p class="mb-0 small text-dark fw-semibold text-success mb-1"><%= @plant.name %></p>
              <p class="mb-0 small text-muted">Hi Desiree! I am feeling great today in the <%= @plant.plant_location.downcase %>. Do you have any questions about my care or the upcoming weather?</p>
            </div>
          </div>

          <div class="d-flex mb-3 justify-content-end">
            <div class="bg-success text-white p-3 rounded-3 shadow-sm" style="max-width: 80%;">
              <p class="mb-0 small">Should I water you today?</p>
            </div>
          </div>

        </div>

        <div class="card-footer bg-white p-3 border-top rounded-bottom-3">
          <div class="input-group">
            <input type="text" class="form-control rounded-pill-start border-success" placeholder="Ask <%= @plant.name %> something..." aria-label="Plant question" disabled>
            <button class="btn btn-success rounded-pill-end px-4 fw-semibold" type="button" disabled>Send</button>
          </div>
          <small class="text-muted d-block mt-2 text-center" style="font-size: 0.75rem;">
            ⚡ OpenAI API connection will be plugged in here next!
          </small>
        </div>

      </div>
    </div>
  </div>
</div>
