<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">

      <div class="card shadow-lg border-0 rounded-4 p-4 p-sm-5 bg-white">

        <div class="text-center mb-4">
          <div class="bg-success text-white rounded-3 p-3 shadow-sm d-inline-flex align-items-center justify-content-center mb-2" style="width: 55px; height: 55px;">
            <i class="fa-solid fa-leaf fs-4"></i>
          </div>
          <h2 class="fw-bold mt-2">Log in</h2>
        </div>

        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="form-inputs">
            <%= f.input :email,
                        required: false,
                        autofocus: true,
                        input_html: { autocomplete: "email" } %>
            <%= f.input :password,
                        required: false,
                        input_html: { autocomplete: "current-password" } %>
            <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
          </div>

          <div class="form-actions mt-4">
            <%= f.button :submit, "Log in", class: "btn btn-primary w-100 rounded-3" %>
          </div>
        <% end %>

        <div class="text-center mt-3 small">
          <%= render "devise/shared/links" %>
        </div>

      </div>

    </div>
  </div>
</div>
